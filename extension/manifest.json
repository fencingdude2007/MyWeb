{
  "manifest_version": 3,
  "name": "MyWeb AI — Save to MyWeb",
  "version": "0.1.0",
  "description": "Save the current page to your personal AI search engine.",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Save to MyWeb"
  },
  "permissions": ["activeTab", "storage", "scripting", "identity", "bookmarks"],
  "host_permissions": ["http://localhost:8000/*"]
}
